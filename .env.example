ELASTICSEARCH_URL=https://api.gdgoc.net
ELASTICSEARCH_INDEX_PATTERN=iis-*
ELASTICSEARCH_TIMEOUT_MS=10000
ELASTIC_USERNAME=
ELASTIC_PASSWORD=

JOBS_POLLING_MINUTES=1
DETECTION_WINDOW_MINUTES=5

# 무차별 대입 탐지
BRUTE_FORCE_MAX_FAILURES=30
BRUTE_FORCE_TARGET_PATHS=/login,/auth,/signin
BRUTE_FORCE_STATUS_CODES=400,401,403
BRUTE_FORCE_EXCLUDED_IPS=

# DDoS 탐지
DDOS_REQUESTS_PER_IP=300
DDOS_EXCLUDED_IPS=

# 웹 서비스 에러 탐지 (4xx)
WEB_ERROR_RATE_PERCENT=10
EXCLUDED_DOMAINS=

# 서버 에러 탐지 (5xx)
SERVER_ERROR_RATE_PERCENT=5

# 민감 경로 탐지
SENSITIVE_PATHS=/.env,/admin,/wp-admin,/phpmyadmin

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
# 형식: user@example.com:domain1|domain2;other@example.com:domain3
SMTP_DOMAIN_RECIPIENTS=

LOG_LEVEL=info
