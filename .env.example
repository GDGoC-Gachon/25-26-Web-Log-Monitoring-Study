ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_TIMEOUT_MS=10000

# Local Docker Compose disables Elasticsearch security for development.
# Configure both values when targeting a secured remote Elasticsearch cluster.
ELASTIC_USERNAME=
ELASTIC_PASSWORD=

KIBANA_URL=http://localhost:5601
KIBANA_TIMEOUT_MS=10000

# Local Docker Compose disables Kibana security for development.
# Configure both values when targeting a secured remote Kibana instance.
KIBANA_USERNAME=
KIBANA_PASSWORD=

JOBS_POLLING_MINUTES=1
RESEND_TOKEN=
